<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="cliente.DetalleController" spacing="8" alignment="TOP_LEFT">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10" />
    </padding>
    <children>
        <Label text="Detalle del Usuario" style="-fx-font-size:14px; -fx-font-weight:bold;" />
        <GridPane hgap="8" vgap="8">
            <columnConstraints>
                <ColumnConstraints minWidth="100" halignment="RIGHT" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <children>
                <Label text="Cédula:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                <Label fx:id="cedulaLabel" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                <Label text="Nombre:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                <Label fx:id="nombreLabel" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                <Label text="Correo:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                <Label fx:id="correoLabel" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                <Label text="Teléfono:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                <Label fx:id="telefonoLabel" GridPane.rowIndex="3" GridPane.columnIndex="1" />

                <Label text="Preferencial:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                <Label fx:id="preferencialLabel" GridPane.rowIndex="4" GridPane.columnIndex="1" />

                <Label text="Tarjeta:" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                <Label fx:id="tarjetaLabel" GridPane.rowIndex="5" GridPane.columnIndex="1" />
            </children>
        </GridPane>
        <Button text="Cerrar" onAction="#handleClose" />
    </children>
</VBox>

